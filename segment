| temperature | -0.254 | +0.254 | 0.0517 | 0.01011 | ~5× |
| brightness | +0.280 | -0.280 | 0.1529 | 0.000001 | ~exact |
| contrast | -0.062 | +0.066 | 0.0142 | 0.00067 | ~21× |
