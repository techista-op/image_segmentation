<script>
const ORDER=["temperature","brightness","contrast","saturation","highlight","shadow"];
const RANGES={temperature:0.3,brightness:0.5,contrast:0.5,saturation:0.6,highlight:0.4,shadow:0.4};
let IMG=null, MASK=null;
let VAL={}; ORDER.forEach(n=>VAL[n]=0);   // current slider value per filter
let SEQ=[];                                // order filters were first moved: ["temperature","shadow",...]
const f=v=>v.toFixed(2);

function cell(rgb,orig,isFg){
  const d=[rgb[0]-orig[0],rgb[1]-orig[1],rgb[2]-orig[2]];
  const big=Math.max(...d.map(Math.abs));
  const ds=big<0.001?"·":`Δ ${d.map(x=>(x>=0?'+':'')+x.toFixed(2)).join(' ')}`;
  const bg=`rgb(${rgb.map(v=>Math.round(v*255)).join(',')})`;
  const dark=(rgb[0]*0.3+rgb[1]*0.6+rgb[2]*0.1)>0.5;
  return `<td class="${isFg?'fg':''}" style="background:${bg}">
    <div class="rgb" style="color:${dark?'#000':'#fff'}">${rgb.map(f).join(' ')}</div>
    <div class="delta" style="color:${dark?'#333':'#bbb'}">${ds}</div></td>`;
}
function drawMatrix(img){
  let h=""; for(let i=0;i<5;i++){h+="<tr>";for(let j=0;j<5;j++)h+=cell(img[i][j],IMG[i][j],MASK[i][j]===1);h+="</tr>";}
  document.getElementById('matrix').innerHTML=h;
}
function statLine(n,s){
  if(n==="temperature")return `meanRGB=[${s.meanR.toFixed(3)}, ${s.meanG.toFixed(3)}, ${s.meanB.toFixed(3)}]  coef=[${s.coefR.toFixed(3)}, ${s.coefG.toFixed(3)}, ${s.coefB.toFixed(3)}]`;
  if(n==="brightness")return `alpha = ${s.alpha.toFixed(3)}`;
  if(n==="contrast")return `threshold = ${s.threshold.toFixed(3)}, x_ = ${s.x_.toFixed(3)}`;
  if(n==="saturation")return s.note;
  if(n==="highlight"||n==="shadow")return `gamma = ${s.gamma.toFixed(3)} (${s.space})`;
  return "";
}
// sequence sent to backend = SEQ order, each with its current value (skip zeros)
function buildSequence(){ return SEQ.filter(n=>VAL[n]!==0).map(n=>({name:n,arg:VAL[n]})); }

async function apply(){
  const fg_only=document.getElementById('fgOnly').checked;
  const sequence=buildSequence();
  const r=await fetch('/api/apply',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({image:IMG,mask:MASK,sequence,fg_only})});
  const data=await r.json();
  const finalImg = data.steps.length ? data.steps[data.steps.length-1].image : IMG;
  drawMatrix(finalImg);
  // tag + history
  document.getElementById('matrixTag').textContent = sequence.length
    ? "— after: " + sequence.map(s=>`${s.name}(${s.arg.toFixed(2)})`).join(" → ")
    : "— no filters applied";
  const seqEl=document.getElementById('seq');
  if(!data.steps.length){ seqEl.innerHTML='<li class="empty">nothing yet — move a slider</li>'; return; }
  seqEl.innerHTML = data.steps.map((s,i)=>
    `<li><span class="step">${i+1}. ${s.name} = ${s.arg.toFixed(2)}</span><br><span class="st">${statLine(s.name,s.stats)}</span></li>`).join("");
  // refresh the order badges on sliders
  ORDER.forEach(n=>{
    const idx=sequence.findIndex(s=>s.name===n);
    document.getElementById('o_'+n).textContent = idx>=0 ? `step ${idx+1}` : "";
  });
}

function onSlide(n,v){
  VAL[n]=v;
  document.getElementById('v_'+n).textContent=v.toFixed(2);
  // first time this filter is moved to a non-zero value -> append to sequence (update in place otherwise)
  if(v!==0 && !SEQ.includes(n)) SEQ.push(n);
  if(v===0 && SEQ.includes(n)) SEQ=SEQ.filter(x=>x!==n);  // back to 0 removes it from the chain
  apply();
}
function sliders(){
  const box=document.getElementById('sliderBox'); box.innerHTML="";
  ORDER.forEach(n=>{
    const row=document.createElement('div'); row.className='slider-row';
    row.innerHTML=`<label>${n} <span><span class="order" id="o_${n}"></span> <span class="val" id="v_${n}">0.00</span></span></label>
      <input type="range" id="s_${n}" min="-1" max="1" step="0.02" value="0">
      <div class="stat">train range ±${RANGES[n]}</div>`;
    box.appendChild(row);
    row.querySelector('input').addEventListener('input',e=>onSlide(n,parseFloat(e.target.value)));
  });
}
document.getElementById('reset').addEventListener('click',()=>{
  ORDER.forEach(n=>{VAL[n]=0;document.getElementById('s_'+n).value=0;document.getElementById('v_'+n).textContent="0.00";document.getElementById('o_'+n).textContent="";});
  SEQ=[]; apply();
});
document.getElementById('fgOnly').addEventListener('change',apply);
(async function(){
  const d=await (await fetch('/api/state')).json(); IMG=d.image; MASK=d.mask;
  drawMatrix(IMG); sliders(); apply();
})();
</script>
</body>
