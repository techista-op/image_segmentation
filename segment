"""
filter_matrix_v2 / app.py   (2-file tool: this + index.html)
-------------------------------------------------------------
5x5 pixel-matrix visualizer for the 6 Harmonizer filters -- see the NUMBERS, not images.

- 5x5 RGB grid, values in [0,1]. Middle 3x3 = FOREGROUND (mask=1), outer ring = BACKGROUND.
- 6 sliders: temperature, brightness, contrast, saturation, highlight, shadow.
- Applied in the SAME ORDER + MATH as src/model/filter.py, on the WHOLE image, then
  composited back through the mask (FG=filtered, BG=original) -- like FilterPerformer.restore().
- CHECKBOX "FG only": when ON, the global stats (temperature channel means, contrast mean)
  are computed over the FOREGROUND ONLY instead of the whole image (the real code uses whole).

Faithful numpy mirror of src/model/filter.py (annotated with source lines). numpy only,
so it runs anywhere.

Run:  pip install flask numpy   then   python app.py   ->  http://127.0.0.1:5000
"""
import os
import numpy as np
from flask import Flask, request, jsonify, send_from_directory

app = Flask(__name__, static_folder=os.path.dirname(os.path.abspath(__file__)))
EPS = 1e-6
FILTER_ORDER = ["temperature", "brightness", "contrast", "saturation", "highlight", "shadow"]


def _mean(img, mask, fg_only, axis):
    """fg_only=False -> plain mean (matches torch.mean in filter.py).
       fg_only=True  -> mean over mask==1 pixels only."""
    if not fg_only:
        return img.mean(axis=axis, keepdims=True)
    m = mask[..., None]
    num = (img * m).sum(axis=axis, keepdims=True)
    den = np.broadcast_to(m, img.shape).sum(axis=axis, keepdims=True) + EPS
    return num / den


def rgb_to_hsv(img):
    r, g, b = img[..., 0], img[..., 1], img[..., 2]
    mx = img.max(-1); mn = img.min(-1); df = mx - mn; v = mx
    s = np.where(mx <= EPS, 0.0, df / (mx + EPS)); nz = df > EPS
    rc = np.where((mx == r) & nz, ((g - b) / (df + EPS)) % 6, 0.0)
    gc = np.where((mx == g) & nz, ((b - r) / (df + EPS)) + 2, 0.0)
    bc = np.where((mx == b) & nz, ((r - g) / (df + EPS)) + 4, 0.0)
    h = (rc + gc + bc) * (np.pi / 3.0)
    return np.stack([h, s, v], -1)


def hsv_to_rgb(img):
    h, s, v = img[..., 0], img[..., 1], img[..., 2]
    h = h / (np.pi / 3.0)
    i = np.floor(h).astype(int) % 6; f = h - np.floor(h)
    p = v * (1 - s); q = v * (1 - f * s); t = v * (1 - (1 - f) * s)
    c = [i == 0, i == 1, i == 2, i == 3, i == 4, i == 5]
    r = np.select(c, [v, q, p, p, t, v]); g = np.select(c, [t, v, v, q, p, p]); b = np.select(c, [p, p, t, v, v, q])
    return np.stack([r, g, b], -1)


# ---- 6 filters: numpy mirror of src/model/filter.py ----
def f_temperature(img, x, mask, fg):                       # TemperatureFilter.forward (122-169)
    R, G, B = img[..., 0:1], img[..., 1:2], img[..., 2:3]
    mR = _mean(R, mask, fg, (0, 1)); mG = _mean(G, mask, fg, (0, 1)); mB = _mean(B, mask, fg, (0, 1))
    gray = (mR + mG + mB) / 3
    aR, aG, aB = 1 - gray / (mR + EPS), 1 - gray / (mG + EPS), 1 - gray / (mB + EPS)
    m = abs(x)
    mR_ = mR + (m if x < 0 else 0); mG_ = mG + (m * 0.5 if x != 0 else 0); mB_ = mB + (m if x > 0 else 0)
    gray_ = (mR_ + mG_ + mB_) / 3
    cR = gray_ / (mR_ + EPS) + aR; cG = gray_ / (mG_ + EPS) + aG; cB = gray_ / (mB_ + EPS) + aB
    out = np.clip(np.concatenate([cR * R, cG * G, cB * B], -1), 0, 1)
    sc = lambda a: float(np.asarray(a).reshape(-1)[0])
    return out, {"meanR": sc(mR), "meanG": sc(mG), "meanB": sc(mB),
                 "coefR": sc(cR), "coefG": sc(cG), "coefB": sc(cB)}


def f_brightness(img, x, mask, fg):                        # BrightnessFilter.forward (15-42)
    alpha = (1.0 / ((1 - x) + EPS)) if x >= 0 else (x + 1)
    if x == 0.0:
        return img.copy(), {"alpha": 1.0}                  # exact identity (no HSV round-trip drift)
    hsv = rgb_to_hsv(img); h, s, v = hsv[..., 0:1], hsv[..., 1:2], hsv[..., 2:3]
    v = v * alpha
    return np.clip(hsv_to_rgb(np.concatenate([h, s, v], -1)), 0, 1), {"alpha": float(alpha)}


def f_contrast(img, x, mask, fg):                          # ContrastFilter.forward (49-70)
    threshold = float(np.asarray(_mean(img, mask, fg, (0, 1, 2))).reshape(-1)[0])
    x_ = (255.0 / (256.0 - np.floor(x * 255.0)) - 1.0) if x > 0 else x
    out = np.clip(img + (img - threshold) * x_, 0, 1)
    return out, {"threshold": threshold, "x_": float(x_)}


def f_saturation(img, x, mask, fg):                        # SaturationFilter.forward (79-113) -- per-pixel
    cmin = img.min(-1, keepdims=True); cmax = img.max(-1, keepdims=True)
    var = cmax - cmin; ran = cmax + cmin; mean = ran / 2
    if x >= 0:
        m = (mean < 0.5).astype(float)
        s = (var / (ran + EPS)) * m + (var / (2 - ran + EPS)) * (1 - m)
        mm = ((x + s) > 1).astype(float)
        a = s * mm + (1 - x) * (1 - mm); a = 1.0 / (a + EPS) - 1.0
        out = img + (img - mean) * a
    else:
        out = mean + (img - mean) * (1 + x)
    return np.clip(out, 0, 1), {"note": "per-pixel (HSL-style), region-independent"}


def f_highlight(img, x, mask, fg):                         # HighlightFilter.forward (176-192)
    g = x + 1
    inv = np.clip(np.power((1 - img) + 1e-9, g), 0, 1)
    return np.clip(1 - inv, 0, 1), {"gamma": float(g), "space": "inverted -> acts on brights"}


def f_shadow(img, x, mask, fg):                            # ShadowFilter.forward (199-211)
    g = -x + 1
    return np.clip(np.power(img + 1e-9, g), 0, 1), {"gamma": float(g), "space": "normal -> acts on darks"}


FILTER_FNS = {"temperature": f_temperature, "brightness": f_brightness, "contrast": f_contrast,
              "saturation": f_saturation, "highlight": f_highlight, "shadow": f_shadow}


def run_pipeline(img0, mask, sequence, fg_only):           # FilterPerformer.restore (module.py 59-68)
    """sequence: list of {name, arg} applied IN THE GIVEN ORDER (the order the user moved
    the sliders). Same masking/composite as the real code; filters can repeat."""
    x = img0.copy(); cur = img0.copy(); steps = []
    m3 = mask[..., None]
    for item in sequence:
        name = item["name"]; arg = float(item["arg"])
        filtered, stats = FILTER_FNS[name](cur, arg, mask, fg_only)
        cur = filtered * m3 + x * (1 - m3)                 # FG filtered, BG keeps original
        steps.append({"name": name, "arg": arg, "stats": stats, "image": cur.round(4).tolist()})
    final = cur.round(4).tolist()
    return steps, final


def default_image():
    img = np.zeros((5, 5, 3))
    img[:] = [0.25, 0.35, 0.75]                            # BG ring: bluish, bright
    fg = [[0.45, 0.20, 0.15], [0.60, 0.30, 0.10], [0.75, 0.25, 0.20],
          [0.55, 0.40, 0.15], [0.70, 0.35, 0.25], [0.50, 0.28, 0.12],
          [0.80, 0.45, 0.30], [0.65, 0.22, 0.18], [0.58, 0.33, 0.22]]
    k = 0
    for i in range(1, 4):
        for j in range(1, 4):
            img[i, j] = fg[k]; k += 1                      # FG 3x3: warm, darker
    return img


def default_mask():
    m = np.zeros((5, 5)); m[1:4, 1:4] = 1.0; return m


@app.route("/")
def index():
    return send_from_directory(app.static_folder, "index.html")


@app.route("/api/state")
def state():
    return jsonify({"image": default_image().round(4).tolist(),
                    "mask": default_mask().tolist(), "order": FILTER_ORDER})


@app.route("/api/apply", methods=["POST"])
def apply():
    d = request.get_json(force=True)
    img = np.array(d["image"], dtype=float)
    mask = np.array(d["mask"], dtype=float)
    fg_only = bool(d.get("fg_only", False))
    sequence = d.get("sequence", [])           # [{name, arg}, ...] in the order moved
    steps, final = run_pipeline(img, mask, sequence, fg_only)
    return jsonify({"steps": steps, "final": final})


if __name__ == "__main__":
    app.run(debug=True, port=5000)
