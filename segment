    y_true_i = compute_y_true(fname, x_scaled[i]).detach()
    abs_err  = torch.abs(y_pred_i - y_true_i)                # [LBS,1]
    err_scalar = float(torch.mean(abs_err).detach())
    # update detached EMA of this filter's error
    prev = self._arg_ema[fname]
    self._arg_ema[fname] = err_scalar if prev is None else decay*prev + (1-decay)*err_scalar
    ema = self._arg_ema[fname] + 1e-6
    w_i = (torch.mean(abs_err).detach() / ema)               # detached weight, scalar
    err_i = w_i * torch.mean(abs_err)                        # grad flows through abs_err only
    l_arg = l_arg + err_i
    k += 1
    self.meters.update('arg_loss_{0}_{1}'.format(i, fname), float(torch.mean(abs_err).detach()))
    self.meters.update('arg_w_{0}_{1}'.format(i, fname), float(w_i))
l_arg = l_arg / max(k, 1)
```
Then the common tail (`loss = fine_loss + u_image_loss + lam*l_arg`).

