"""
demo_inverse_on_sample.py
=========================
Demonstrates the closed-form inverse-argument idea on the real sample image
(sample/image.jpg + sample/mask.png), branch loss_function.

Pipeline (mirrors the training degrade->restore, but with KNOWN args):
  1. load image + mask (FG = white in mask)
  2. for each of the 6 filters, pick a random degrade arg x
  3. degrade: apply filter(x) to the FG region only (composite with original BG)
  4. compute closed-form recovery arg y = inverse(x[, stats])
  5. restore: apply filter(y) to the degraded image (FG region)
  6. measure how well restore matches the original FG (excl. clamped pixels)
  7. save a side-by-side panel and a JSON of {x, y, errors} per filter

Pure numpy replica of module/filter.py math (whole-image stats, paper conv.).
Runs on CPU in well under a second.
"""
import os, json
import numpy as np
from PIL import Image

from inverse_targets import compute_inverse_arg

EPS = 1e-6
HERE = os.path.dirname(os.path.abspath(__file__))
SAMPLE = os.path.join(HERE, 'sample')
OUT = os.path.join(SAMPLE, 'inverse_demo')
os.makedirs(OUT, exist_ok=True)
np.random.seed(7)

# ---------------- filter.py replicas (whole-image stats) ----------------
def rgb_to_hsv(img):
    r,g,b=img[0],img[1],img[2]
    maxc=np.max(img,axis=0); minc=np.min(img,axis=0); v=maxc; d=maxc-minc
    s=np.where(maxc>0,d/(maxc+EPS),0.0); ds=np.where(d==0,1.0,d)
    rc=(maxc-r)/ds; gc=(maxc-g)/ds; bc=(maxc-b)/ds; h=np.zeros_like(maxc)
    h=np.where(maxc==r,bc-gc,h); h=np.where(maxc==g,2.0+rc-bc,h); h=np.where(maxc==b,4.0+gc-rc,h)
    h=(h/6.0)%1.0; h=np.where(d==0,0.0,h); return np.stack([h*2*np.pi,s,v],axis=0)
def hsv_to_rgb(img):
    h=img[0]/(2*np.pi); s=img[1]; v=img[2]; h6=(h%1.0)*6.0; i=np.floor(h6).astype(int); f=h6-i
    p=v*(1-s); q=v*(1-s*f); t=v*(1-s*(1-f)); i=i%6
    r=np.choose(i,[v,q,p,p,t,v]); g=np.choose(i,[t,v,v,q,p,p]); b=np.choose(i,[p,p,t,v,v,q]); return np.stack([r,g,b],axis=0)
def cl(x): return np.clip(x,0.0,1.0)

def f_temperature(img,x):
    R,G,B=img[0:1],img[1:2],img[2:3]
    mR,mG,mB=R.mean(),G.mean(),B.mean(); gray=(mR+mG+mB)/3
    aR=1-gray/(mR+EPS); aG=1-gray/(mG+EPS); aB=1-gray/(mB+EPS)
    ip=1.0 if x>0 else 0.0; ineg=1.0 if x<0 else 0.0; iz=1.0 if x==0 else 0.0
    mR_=mR+x*np.sign(x)*ineg; mG_=mG+x*np.sign(x)*0.5*(1-iz); mB_=mB+x*np.sign(x)*ip
    gray_=(mR_+mG_+mB_)/3
    cR=gray_/(mR_+EPS)+aR; cG=gray_/(mG_+EPS)+aG; cB=gray_/(mB_+EPS)+aB
    return cl(np.concatenate([cR*R,cG*G,cB*B],axis=0))
def f_brightness(img,x):
    hsv=rgb_to_hsv(img); h,s,v=hsv[0:1],hsv[1:2],hsv[2:3]
    a=(1/((1-x)+EPS)) if x>=0 else (x+1); v=v*a
    return cl(hsv_to_rgb(np.concatenate([h,s,v],axis=0)))
def f_contrast(img,x):
    th=img.mean(); x_=255/(256-np.floor(x*255))-1 if x>0 else x; return cl(img+(img-th)*x_)
def f_saturation(img,x):
    cmin=img.min(0,keepdims=True); cmax=img.max(0,keepdims=True); var=cmax-cmin; ran=cmax+cmin; mean=ran/2
    if x>=0:
        m=(mean<0.5).astype(float); s=(var/(ran+EPS))*m+(var/(2-ran+EPS))*(1-m)
        mm=((x+s)>1).astype(float); a=s*mm+(1-x)*(1-mm); a=1/(a+EPS)-1; return cl(img+(img-mean)*a)
    return cl(mean+(img-mean)*(1+x))
def f_highlight(img,x): return cl(1.0-cl(np.power(1.0-img+1e-9,x+1)))
def f_shadow(img,x): return cl(np.power(img+1e-9,-x+1))

FILTERS = {
    'temperature': f_temperature, 'brightness': f_brightness, 'contrast': f_contrast,
    'saturation': f_saturation, 'highlight': f_highlight, 'shadow': f_shadow,
}
# paper degrade ranges (Harmonizer.filter_argument_ranges)
RANGES = {'temperature':0.3,'brightness':0.5,'contrast':0.5,'saturation':0.6,'highlight':0.4,'shadow':0.4}

def composite(filt, orig, mask): return filt*mask + orig*(1-mask)

def load():
    img = Image.open(os.path.join(SAMPLE,'image.jpg')).convert('RGB')
    mask = Image.open(os.path.join(SAMPLE,'mask.png')).convert('L').resize(img.size)
    a = np.asarray(img, np.float64).transpose(2,0,1)/255.0
    m = (np.asarray(mask, np.float64)/255.0)[None,:,:]
    m = (m>0.5).astype(np.float64)
    return a, m

def to_uint8(a): return (cl(a)*255).astype(np.uint8).transpose(1,2,0)

def main():
    img, mask = load()
    fg_px = mask.sum()*3
    print(f"image {img.shape}  FG fraction = {mask.mean():.3f}")
    results = {}
    panels = []
    for name, f in FILTERS.items():
        x = float(np.random.uniform(-1,1) * RANGES[name])   # degrade arg (scaled like training)
        # degrade FG only
        degraded = composite(f(img, x), img, mask)
        # closed-form recovery arg (needs image for temperature stats)
        y = compute_inverse_arg(name, x, image=degraded)
        # restore FG only
        restored = composite(f(degraded, y), degraded, mask)
        # error on FG, excluding clamped pixels
        mask3 = np.repeat(mask, 3, axis=0)
        clipped = (degraded<=0.0)|(degraded>=1.0)
        fgsel = (mask3>0.5) & (~clipped)
        n = fgsel.sum()
        err_fg = np.abs(restored-img)[fgsel].mean() if n else 0.0
        # baseline: error if we did NOTHING (degraded vs original) on FG
        err_none = np.abs(degraded-img)[mask3>0.5].mean()
        results[name] = {
            'degrade_x': round(x,5),
            'recovery_y': round(float(y),5),
            'fg_recover_err_unclipped': round(float(err_fg),6),
            'fg_degrade_err': round(float(err_none),6),
            'improvement_x': round(float(err_none/(err_fg+1e-9)),2),
        }
        panels.append((name, img, degraded, restored))
        print(f"  {name:11s} x={x:+.3f} -> y={y:+.3f} | degrade_err={err_none:.4f}  "
              f"recover_err={err_fg:.5f}  ({err_none/(err_fg+1e-9):.0f}x better)")

    # save per-filter triptychs (orig | degraded | restored)
    for name, o, d, r in panels:
        strip = np.concatenate([to_uint8(o), to_uint8(d), to_uint8(r)], axis=1)
        Image.fromarray(strip).save(os.path.join(OUT, f'{name}.png'))

    # one big montage: rows = filters, cols = orig|degraded|restored
    rows = [np.concatenate([to_uint8(o),to_uint8(d),to_uint8(r)],axis=1) for _,o,d,r in panels]
    montage = np.concatenate(rows, axis=0)
    Image.fromarray(montage).save(os.path.join(OUT,'montage_all_filters.png'))

    with open(os.path.join(OUT,'inverse_results.json'),'w') as fjson:
        json.dump(results, fjson, indent=2)
    print(f"\nSaved -> {OUT}")
    print("  montage_all_filters.png, <filter>.png, inverse_results.json")

if __name__ == '__main__':
    main()

